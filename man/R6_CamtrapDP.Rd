\subsection{\code{CamtrapDP$set_taxon()}}{
  Sets taxonomic coverage from the observations. The Camtrap DP
\code{taxonomic} block requires a \code{taxonID} (e.g. a GBIF / IUCN identifier or
URI), which is looked up with \code{taxadb}; \code{taxadb} is therefore a required
dependency of the package (loaded with it, as in previous versions).
Names that cannot be matched get \code{taxonID = NA} (omitted from the output
rather than a bogus \verb{<uri>NA}). A \code{warning()} is emitted for
\code{scientificName} values with unnecessary whitespace and for names with no
\code{taxonID} in the chosen database.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CamtrapDP$set_taxon(taxonDB = "gbif")}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{taxonDB}}{Taxon database passed to taxadb: \code{"gbif"} (default),
\code{"itis"} or \code{"ncbi"}.}
    }
    \if{html}{\out{</div>}}
  }
}

