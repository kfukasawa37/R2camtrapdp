\if{html}{\out{<a id="method-CamtrapDP-validate"></a>}}
\if{latex}{\out{\hypertarget{method-CamtrapDP-validate}{}}}
\subsection{\code{CamtrapDP$validate()}}{
  Aggregate validation: per-table schema issues collected at
build time plus cross-table relation checks. Optionally also runs the
Python Frictionless validation.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CamtrapDP$validate(
  relations = TRUE,
  metadata = FALSE,
  conformance = FALSE,
  frictionless = FALSE,
  summarize = TRUE,
  ...
)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{relations}}{Whether to run \code{check_relations()}.}
      \item{\code{metadata}}{Whether to run \code{check_metadata()} (profile-driven).}
      \item{\code{conformance}}{Whether to run the Frictionless conformance pre-checks
\code{check_descriptor()} and \code{check_camtrap_profile()}.}
      \item{\code{frictionless}}{Whether to also run \code{validate_frictionless()}.}
      \item{\code{summarize}}{Whether to print a summary.}
      \item{\code{...}}{Passed to \code{validate_frictionless()}.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    An issue table.
  }
}

\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-CamtrapDP-validate_frictionless"></a>}}
\if{latex}{\out{\hypertarget{method-CamtrapDP-validate_frictionless}{}}}
\subsection{\code{CamtrapDP$validate_frictionless()}}{
  Run the Python Frictionless validation on the written data
package and parse the report into an issue table.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CamtrapDP$validate_frictionless(
  directory = NULL,
  python = "python",
  script = NULL,
  write = TRUE,
  patch_profile = TRUE,
  summarize = TRUE
)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{directory}}{Directory containing (or to receive) the data package.
Defaults to a temporary directory; the package is written there first.}
      \item{\code{python}}{Path to the Python interpreter.}
      \item{\code{script}}{Path to \code{frictionless_validate.py}. If \code{NULL}, resolved
from \code{getOption("camtrapdp.frictionless_script")}, else the installed
copy (\code{system.file("python/frictionless_validate.py", package = "R2camtrapdp")}), else the loose-source \code{python/frictionless_validate.py}.}
      \item{\code{write}}{Whether to (re)write the data package before validating.}
      \item{\code{patch_profile}}{If \code{TRUE}, work around the malformed internal
\verb{$ref} (\verb{#$defs/version}) in the Camtrap DP 1.0 profile by validating
against a locally corrected copy. The written \code{datapackage.json} keeps
the canonical profile URL; only a separate validation descriptor is
patched. Has no effect for 1.0.1 / 1.0.2 (their profiles are correct).}
      \item{\code{summarize}}{Whether to print a summary.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    An issue table (engine \code{"frictionless"}).
  }
}

