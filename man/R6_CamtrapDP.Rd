\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-CamtrapDP-check_descriptor"></a>}}
\if{latex}{\out{\hypertarget{method-CamtrapDP-check_descriptor}{}}}
\subsection{\code{CamtrapDP$check_descriptor()}}{
  Pre-check that the package descriptor and its table schemas
conform to the Frictionless specification, before the authoritative
Python Frictionless step. Checks the package structure (non-empty
\code{resources}; each resource has \code{name} and \code{path}/\code{data}; unique names;
\code{profile} set) and the well-formedness of every loaded / inline table
schema (\code{ctdp_check_schema()}). Optionally runs a full JSON Schema
validation of the written descriptor when \code{jsonschema} is given and the
\code{jsonvalidate} package is installed.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CamtrapDP$check_descriptor(
  check_schemas = TRUE,
  jsonschema = NULL,
  summarize = TRUE
)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{check_schemas}}{Also check each table schema's well-formedness.}
      \item{\code{jsonschema}}{Optional path/URL to a JSON Schema to validate the
serialized descriptor against (requires the \code{jsonvalidate} package).}
      \item{\code{summarize}}{Print a summary.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    An issue table (see \code{\link[=ctdp_issues]{ctdp_issues()}}).
  }
}

